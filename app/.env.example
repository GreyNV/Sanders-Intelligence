# Supabase — copy from Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Used by the Edge Function (server-side only, never expose in frontend)
# Set this in Supabase Dashboard → Edge Functions → Secrets
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# SellerCloud REST credentials for sync-purchase-orders Edge Function
SELLERCLOUD_DELTA_BASE=https://snc.api.sellercloud.com/rest
SELLERCLOUD_USERNAME=your-sellercloud-username
SELLERCLOUD_PASSWORD=your-sellercloud-password
